{
  "#type": "merge",
  "depth": -1,
  "values": [
    "$.current",
    {
      "results": {
        "request": {
          "aggregations": {
            "parlimentaryarchive": {
              "filter": {
                "prefix": {
                  "identifier.__reference_number.keyword": "Y"
                }
              },
              "aggregations": {
                "parliamentary_series": {
                  "terms": {
                    "field": "identifier.__reference_number.keyword",
                    "size": 500
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
