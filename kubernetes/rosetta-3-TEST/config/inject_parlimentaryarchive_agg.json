{
  "#type": "merge",
  "depth": -1,
  "values": [
    "$.current",
    {
      "results": {
        "request": {
          "aggregations": {
            "parliamentaryArchive": {
              "filter": {
                "bool": {
                  "must": [
                    {
                      "query_string": {
                        "query": "source.value:UNKNOWN"
                      }
                    },
                    {
                      "prefix": {
                        "@hierarch.identifier.value": "Y"
                      }
                    }
                  ]
                }
              },
              "aggregations": {
                "parliamentary_series": {
                  "terms": {
                    "field": "@hierarch.identifier.value",
                    "size": 500
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}


