{
  "#type": "merge",
  "depth": -1,
  "values": [
    "$.current",
    {
      "#type": "require",
      "require": "$.original.query[?(@.parlimentaryarchive == 'true')]",
      "value": {
        "results": {
          "request": {
            "aggregations": {
              "parlimentaryarchive": {
                "filter": {
                  "bool": {
                    "must": [
                      {
                        "query_string": {
                          "query": "source.value:UNKNOWN"
                        }
                      },
                      {
                        "prefix": {
                          "identifier.__reference_number.keyword": "Y"
                        }
                      }
                    ]
                  }
                },
                "aggregations": {
                  "parliamentary_series": {
                    "terms": {
                      "script": {
                        "source": "String ref = doc['identifier.__reference_number.keyword'].value; int idx = ref.indexOf('/'); return idx > -1 ? ref.substring(0, idx) : ref;"
                      },
                      "size": 500
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}