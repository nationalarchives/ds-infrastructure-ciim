{
  "#type": "merge",
  "depth": -1,
  "values": [
    "$.current",
    {
      "#type": "require",
      "require": "$.original.query[?(@.parlimentaryarchive == 'true')]",
      "value": {
        "results": {
          "request": {
            "aggregations": {
              "parliamentaryarchive": {
                "filter": {
                  "query_string": {
                    "query": "@hierarch.source.value:\"UNKNOWN\" AND @hierarch.level.code:1"
                  }
                },
                "aggregations": {
                  "parliamentary_series": {
                    "terms": {
                      "field": "@hierarch.identifier.__reference_number.keyword",
                      "include": "Y.*",
                      "size": 500
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}